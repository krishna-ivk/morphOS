{
  "name": "feature_pipeline",
  "steps": [
    {
      "id": "interpret_vision",
      "type": "agent",
      "agent": "vision_agent",
      "contracts": [
        {
          "name": "feature_plan",
          "path": "${artifacts_dir}/feature_plan.json",
          "kind": "json_schema",
          "schema_name": "FeaturePlan"
        }
      ]
    },
    {
      "id": "split_tasks",
      "type": "program",
      "command": "python3 scripts/task_split.py ${artifacts_dir}/feature_plan.json ${artifacts_dir}/tasks.json",
      "contracts": [
        {
          "name": "task_list",
          "path": "${artifacts_dir}/tasks.json",
          "kind": "json_schema",
          "schema_name": "TaskList"
        }
      ]
    },
    {
      "id": "implement_features",
      "type": "parallel_agents",
      "agent": "coding_agent",
      "items_from": "tasks.json",
      "max_parallel": 4
    },
    {
      "id": "run_tests",
      "type": "program",
      "command": "bash programs/run_tests.sh ${run_id} ${validation_dir}",
      "contracts": [
        {
          "name": "test_results",
          "path": "${validation_dir}/test_results.json",
          "kind": "json_schema",
          "schema_name": "TestResults"
        }
      ],
      "signals": [
        {
          "name": "test_failure_signal",
          "path": "${validation_dir}/test_results.json",
          "json_path": "overall_result",
          "equals": "fail",
          "context_key": "test_failure"
        }
      ]
    },
    {
      "id": "fix_errors",
      "type": "conditional_agent",
      "condition": "test_failure",
      "agent": "debugging_agent"
    },
    {
      "id": "learn_from_run",
      "type": "agent",
      "agent": "learning_agent"
    }
  ]
}
