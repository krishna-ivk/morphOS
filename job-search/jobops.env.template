# JobOps env template for local setup
#
# Copy the values you want into:
# /Users/shivakrishnayadav/Documents/skyforce/job-search/job-ops/.env

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# The UI can also store these during onboarding, but it helps to know what you
# plan to use before launching.

# Common examples:
# MODEL=gpt-4.1-mini
# MODEL=openai/gpt-4.1-mini
# MODEL=google/gemini-2.5-flash
MODEL=

# If your provider needs a general API key, set it here.
LLM_API_KEY=

# Optional provider-specific values if you use them instead of LLM_API_KEY.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# RxResume
# -----------------------------------------------------------------------------
# Recommended if you want tailored PDFs.
# Current docs recommend v5 API-key mode where possible.

# RXRESUME_MODE=v5
RXRESUME_MODE=
RXRESUME_URL=
RXRESUME_API_KEY=

# If you use the legacy v4 flow instead:
RXRESUME_EMAIL=
RXRESUME_PASSWORD=

# -----------------------------------------------------------------------------
# Gmail OAuth
# -----------------------------------------------------------------------------
# Optional. Only needed for post-application email tracking.

GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3005/oauth/gmail/callback

# -----------------------------------------------------------------------------
# Optional auth / public URL
# -----------------------------------------------------------------------------

BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
JOBOPS_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Optional extractors
# -----------------------------------------------------------------------------

ADZUNA_APP_ID=
ADZUNA_APP_KEY=

UKVISAJOBS_EMAIL=
UKVISAJOBS_PASSWORD=
UKVISAJOBS_HEADLESS=true

# -----------------------------------------------------------------------------
# Optional search defaults
# -----------------------------------------------------------------------------

JOBSPY_IS_REMOTE=0
